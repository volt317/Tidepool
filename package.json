{
  "name": "tidepool",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "Tidepool \u2014 distro-first change intelligence service (TypeScript): comprehensive per-distro package lists aggregated from each distro's information sources, GPG-verified where the distro signs.",
  "scripts": {
    "generate:deploy-config": "node scripts/generate-deploy-config.mjs",
    "check:deploy-config": "node scripts/generate-deploy-config.mjs --check",
    "sync:locks": "./scripts/sync-component-locks.sh",
    "check:locks": "./scripts/sync-component-locks.sh --check",
    "check:node": "node scripts/assert-node24.mjs",
    "check:image-node": "./deploy/scripts/verify-image-node.sh",
    "build:server": "node scripts/generate-deploy-config.mjs && tsc -p server",
    "build:web": "npm --prefix web run build",
    "build": "npm run build:server && npm run build:web",
    "typecheck": "tsc -p server --noEmit && tsc -p web",
    "lint": "eslint .",
    "dev:server": "npm run build:server && node server/dist/server/src/index.js",
    "dev:web": "npm --prefix web run dev",
    "start": "TIDEPOOL_SERVE_STATIC=1 node server/dist/server/src/index.js",
    "smoke": "node scripts/smoke.mjs",
    "test": "npm run build:server && node --test --enable-source-maps 'server/dist/server/test/*.test.js'",
    "test:coverage": "npm run build:server && mkdir -p coverage && node --test --enable-source-maps --experimental-test-coverage --test-coverage-include='**/server/src/**' --test-coverage-lines=65 --test-coverage-branches=70 --test-coverage-functions=68 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info 'server/dist/server/test/*.test.js'",
    "start:collector": "node server/dist/server/src/services/collector.js",
    "start:api": "node server/dist/server/src/services/api.js",
    "start:scheduler": "node server/dist/server/src/services/scheduler.js",
    "start:proxy": "node server/dist/server/src/services/proxy.js",
    "admin": "node server/dist/server/src/cli/admin.js",
    "retention": "node server/dist/server/src/cli/retention.js",
    "tls": "node server/dist/server/src/cli/tls.js"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "server",
    "web"
  ]
}