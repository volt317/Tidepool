# deploy/apparmor/tidepool-corpus-import
#
# AppArmor profile for corpus IMPORT/RESTORE jobs: read a validated bundle,
# write the authoritative corpus. This is the ONLY profile besides the
# collector's allowed to write the writer path — which is exactly why import
# is an administratively invoked, normally-stopped operation (restore.sh
# stops the collector first; two writers never coexist). No network.
#
# Run shape:
#   podman run --rm --network=none --security-opt apparmor=tidepool-corpus-import \
#     -v "$TIDEPOOL_HOME/backups:/var/lib/tidepool/backups:ro" \
#     -v "$TIDEPOOL_HOME/corpus:/var/lib/tidepool/corpus:rw" \
#     localhost/tidepool-utility:<tag> node server/dist/server/src/cli/corpus.js import …

abi <abi/3.0>,
include <tunables/global>

profile tidepool-corpus-import flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>

  /usr/local/bin/node ix,
  deny /{usr/,}bin/{da,ba,}sh x,
  deny /usr/bin/** x,
  deny /usr/local/bin/{npm,npx,corepack}* x,

  deny network inet,
  deny network inet6,
  deny network raw,
  deny network packet,

  /app/ r,
  /app/** r,
  # validated bundle source: read-only
  /var/lib/tidepool/backups/ r,
  /var/lib/tidepool/backups/** r,
  # authoritative corpus: the restore target
  /var/lib/tidepool/corpus/ rw,
  /var/lib/tidepool/corpus/** rwk,

  deny /var/lib/tidepool/keyrings/** rwklx,
  deny /var/lib/tidepool/cache/** rwklx,
  deny /var/lib/tidepool/run/** rwklx,
  deny /var/lib/tidepool/published/** rwklx,

  owner /tmp/ rw,
  owner /tmp/** rwk,
  owner @{PROC}/@{pid}/maps r,
  owner @{PROC}/@{pid}/status r,
  @{PROC}/sys/kernel/hostname r,
  /etc/localtime r,
  /usr/share/zoneinfo/** r,

  deny capability,
  deny mount,
  deny umount,
  deny pivot_root,
  deny ptrace,
  deny /proc/sys/** w,
  deny /sys/** w,
  deny /app/** w,

  signal (receive) set=(term, kill, int, quit, hup) peer=unconfined,
}
