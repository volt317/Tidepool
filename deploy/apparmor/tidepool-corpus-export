# deploy/apparmor/tidepool-corpus-export
#
# AppArmor profile for corpus EXPORT jobs (corpus.js export): read the
# corpus, write one bundle to the designated exports destination. Export is
# NOT dispatch and does not reuse dispatch authority: it can read the whole
# corpus (dispatch cannot) and it cannot see project paths (dispatch can).
# No network of any kind.
#
# Run shape:
#   podman run --rm --network=none --security-opt apparmor=tidepool-corpus-export \
#     -v "$TIDEPOOL_HOME/corpus:/var/lib/tidepool/corpus:ro" \
#     -v "$TIDEPOOL_HOME/exports:/var/lib/tidepool/exports:rw" \
#     localhost/tidepool-utility:<tag> node server/dist/server/src/cli/corpus.js export …

abi <abi/3.0>,
include <tunables/global>

profile tidepool-corpus-export flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>

  /usr/local/bin/node ix,
  deny /{usr/,}bin/{da,ba,}sh x,
  deny /usr/bin/** x,
  deny /usr/local/bin/{npm,npx,corepack}* x,

  deny network inet,
  deny network inet6,
  deny network raw,
  deny network packet,

  /app/ r,
  /app/** r,
  # corpus: read everything (an export IS a corpus read). Reading a live WAL
  # database additionally requires write+lock on the writer's -shm/-wal
  # sidecars (SQLite's shared-memory reader index) — granted for exactly
  # those files and nothing else; objects/snapshots stay read-only.
  /var/lib/tidepool/corpus/ r,
  /var/lib/tidepool/corpus/** rk,
  /var/lib/tidepool/corpus/writer/tidepool.sqlite3 rwk,
  /var/lib/tidepool/corpus/writer/tidepool.sqlite3-shm rwk,
  /var/lib/tidepool/corpus/writer/tidepool.sqlite3-wal rwk,
  # destination: write the bundle
  /var/lib/tidepool/exports/ rw,
  /var/lib/tidepool/exports/** rwk,

  deny /var/lib/tidepool/keyrings/** rwklx,
  deny /var/lib/tidepool/cache/** rwklx,
  deny /var/lib/tidepool/run/** rwklx,

  owner /tmp/ rw,
  owner /tmp/** rwk,
  owner @{PROC}/@{pid}/maps r,
  owner @{PROC}/@{pid}/status r,
  @{PROC}/sys/kernel/hostname r,
  /etc/localtime r,
  /usr/share/zoneinfo/** r,

  deny capability,
  deny mount,
  deny umount,
  deny pivot_root,
  deny ptrace,
  deny /proc/sys/** w,
  deny /sys/** w,
  deny /app/** w,

  signal (receive) set=(term, kill, int, quit, hup) peer=unconfined,
}
