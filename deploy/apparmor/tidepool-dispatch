# deploy/apparmor/tidepool-dispatch
#
# AppArmor profile for ad-hoc runs of the tidepool-utility image — dispatch
# analysis ("snapshot × project paths → findings artifact") and corpus
# export/import. Dispatch inspects LOCAL project trees, i.e. bytes the
# operator points it at; the profile guarantees the analysis can look but
# not touch, and cannot reach the network at all.
#
# Usage (the project is mounted read-only at /project, findings land in the
# corpus exports tree):
#   podman run --rm --network=none --security-opt apparmor=tidepool-dispatch \
#     -v ~/.local/share/tidepool/corpus:/var/lib/tidepool/corpus:rw \
#     -v /path/to/project:/project:ro \
#     localhost/tidepool-utility \
#     node server/dist/server/src/cli/dispatch.js --snapshot latest \
#       --store /var/lib/tidepool/corpus \
#       --out /var/lib/tidepool/corpus/exports/dispatch.json /project
#
# Load: sudo install -m 644 tidepool-dispatch /etc/apparmor.d/ && sudo apparmor_parser -r /etc/apparmor.d/tidepool-dispatch

abi <abi/3.0>,
include <tunables/global>

profile tidepool-dispatch flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>

  # node only
  /usr/local/bin/node ix,
  deny /{usr/,}bin/{da,ba,}sh x,
  deny /usr/bin/** x,
  deny /usr/local/bin/{npm,npx,corepack}* x,

  # ---------------------------------------------------------- NO network
  # Dispatch is the offline half of the design: snapshots are bounded truth,
  # evaluated without re-collection. Pair with podman's --network=none; the
  # profile makes it policy.
  deny network,

  # code + corpus (snapshots read, exports written, the SQLite store is
  # opened by the corpus CLI for status/import — hence rwk on the tree)
  /app/ r,
  /app/** r,
  /var/lib/tidepool/corpus/ rw,
  /var/lib/tidepool/corpus/** rwk,

  # the supplied project: readable, NEVER writable — analysis must not be
  # able to modify what it judges
  /project/ r,
  /project/** r,
  deny /project/** wklx,

  owner /tmp/ rw,
  owner /tmp/** rwk,
  owner @{PROC}/@{pid}/maps r,
  owner @{PROC}/@{pid}/status r,
  owner @{PROC}/@{pid}/stat r,
  owner @{PROC}/@{pid}/task/ r,
  owner @{PROC}/@{pid}/task/** r,
  owner @{PROC}/@{pid}/fd/ r,
  /sys/fs/cgroup/** r,
  /etc/localtime r,
  /usr/share/zoneinfo/** r,

  deny capability,
  deny mount,
  deny umount,
  deny pivot_root,
  deny ptrace,
  deny /proc/kcore r,
  deny /proc/sys/** w,
  deny /sys/** w,
  deny /dev/mem rw,
  deny /dev/kmem rw,
  deny /dev/port rw,
  deny /app/** w,

  signal (receive) set=(term, kill, int, quit, hup) peer=unconfined,
  signal (send, receive) peer=tidepool-dispatch,
}
