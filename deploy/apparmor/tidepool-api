# deploy/apparmor/tidepool-api
#
# AppArmor profile for the Tidepool API container (isolated-appliance form).
#
# The API now runs with Network=none and reads only PUBLISHED truth, which
# lets this profile make claims the previous pod-form could not:
#
#   * inet/inet6 are DENIED OUTRIGHT — with no network namespace the only
#     legitimate sockets are unix (the run/ listener). "The API cannot
#     contact the Internet" is enforced twice: no netns, and no inet
#     socket family.
#   * the WRITER path is denied BY NAME. It also isn't mounted; the deny
#     rule means even a mount-configuration mistake doesn't silently
#     reopen the door.
#   * the published replica, objects, and snapshots are READ-ONLY at the
#     profile level — matching the read-only mounts and the
#     SQLITE_OPEN_READONLY connection. Three layers must all fail before
#     the API can write corpus-derived state.
#
# Load: sudo install -m 644 tidepool-api /etc/apparmor.d/ && sudo apparmor_parser -r /etc/apparmor.d/tidepool-api

abi <abi/3.0>,
include <tunables/global>

profile tidepool-api flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>

  # ------------------------------------------------------------ execution
  /usr/local/bin/node ix,
  deny /{usr/,}bin/{da,ba,}sh x,
  deny /usr/bin/** x,
  deny /usr/local/bin/{npm,npx,corepack}* x,

  # ------------------------------------------------------------ networking
  # unix only: the api.sock listener and health checks. No inet at all —
  # the container has no network namespace (Network=none) and this profile
  # keeps that true even if the unit were misconfigured.
  network unix stream,
  deny network inet,
  deny network inet6,
  deny network raw,
  deny network packet,

  # ------------------------------------------------------------ filesystem
  /app/ r,
  /app/** r,
  /var/lib/tidepool/config/ r,
  /var/lib/tidepool/config/** r,

  # published replica: read-only (the API's SQLite connection is
  # SQLITE_OPEN_READONLY against an atomically replaced file — no WAL/-shm
  # cooperation needed, so no write or lock grants either)
  /var/lib/tidepool/published/ r,
  /var/lib/tidepool/published/** r,

  # normalized record blobs + finalized snapshots: the two read-only trees
  # state reconstruction strictly requires
  /var/lib/tidepool/corpus/objects/ r,
  /var/lib/tidepool/corpus/objects/** r,
  /var/lib/tidepool/corpus/snapshots/ r,
  /var/lib/tidepool/corpus/snapshots/** r,

  # the AUTHORITATIVE WRITER — denied by name, belt over the missing mount
  deny /var/lib/tidepool/corpus/writer/ rwklx,
  deny /var/lib/tidepool/corpus/writer/** rwklx,
  # everything else under corpus/ (exports, locks…): not the API's business
  deny /var/lib/tidepool/corpus/exports/** rwklx,

  # runtime sockets: create/bind api.sock
  /var/lib/tidepool/run/ rw,
  /var/lib/tidepool/run/** rwk,

  # keyrings and the collector-private cache: no reason to exist here
  deny /var/lib/tidepool/keyrings/** rwklx,
  deny /var/lib/tidepool/cache/** rwklx,

  owner /tmp/ rw,
  owner /tmp/** rwk,

  owner @{PROC}/@{pid}/maps r,
  owner @{PROC}/@{pid}/status r,
  owner @{PROC}/@{pid}/stat r,
  owner @{PROC}/@{pid}/task/ r,
  owner @{PROC}/@{pid}/task/** r,
  owner @{PROC}/@{pid}/fd/ r,
  @{PROC}/sys/kernel/hostname r,
  /sys/fs/cgroup/** r,
  /etc/hosts r,
  /etc/nsswitch.conf r,
  /etc/ssl/certs/ r,
  /etc/ssl/certs/** r,
  /etc/localtime r,
  /usr/share/zoneinfo/** r,

  # ------------------------------------------------------- explicit denials
  deny capability,
  deny mount,
  deny umount,
  deny pivot_root,
  deny ptrace,
  deny /proc/kcore r,
  deny /proc/sys/** w,
  deny /sys/** w,
  deny /dev/mem rw,
  deny /dev/kmem rw,
  deny /dev/port rw,
  deny /var/lib/tidepool/config/** w,
  deny /app/** w,

  signal (receive) set=(term, kill, int, quit, hup) peer=unconfined,
  signal (send, receive) peer=tidepool-api,
}
