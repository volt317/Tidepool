# deploy/apparmor/tidepool-scheduler
#
# AppArmor profile for the Tidepool SCHEDULER container — the smallest trust
# domain in the appliance. It holds no data access whatsoever: no corpus, no
# keyrings, no cache — and, in the isolated-appliance form, NO INET SOCKETS:
# it runs with Network=none, dials the collector over the Unix control
# socket, and its health signal is a heartbeat file. The inet denial below
# is enforceable precisely because of that design.
#
# Load: sudo install -m 644 tidepool-scheduler /etc/apparmor.d/ && sudo apparmor_parser -r /etc/apparmor.d/tidepool-scheduler

abi <abi/3.0>,
include <tunables/global>

profile tidepool-scheduler flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>

  # node only, nothing else ever executes
  /usr/local/bin/node ix,
  deny /{usr/,}bin/{da,ba,}sh x,
  deny /usr/bin/** x,
  deny /usr/local/bin/{npm,npx,corepack}* x,

  # unix only: the collector control socket. No inet of any kind.
  network unix stream,
  deny network inet,
  deny network inet6,
  deny network raw,
  deny network packet,

  # read code + config; NOTHING under /var/lib/tidepool is writable, and the
  # corpus/keyrings are not even readable — the mounts don't exist in this
  # container, and the profile guarantees it stays that way
  /app/ r,
  /app/** r,
  /var/lib/tidepool/config/ r,
  /var/lib/tidepool/config/** r,
  # runtime: dial the control socket, write its own heartbeat — nothing else
  /var/lib/tidepool/run/ rw,
  /var/lib/tidepool/run/** rwk,
  deny /var/lib/tidepool/corpus/** rwklx,
  deny /var/lib/tidepool/keyrings/** rwklx,
  deny /var/lib/tidepool/cache/** rwklx,
  deny /var/lib/tidepool/published/** rwklx,

  owner /tmp/ rw,
  owner /tmp/** rwk,
  owner @{PROC}/@{pid}/maps r,
  owner @{PROC}/@{pid}/status r,
  owner @{PROC}/@{pid}/stat r,
  owner @{PROC}/@{pid}/task/ r,
  owner @{PROC}/@{pid}/task/** r,
  owner @{PROC}/@{pid}/fd/ r,
  @{PROC}/sys/kernel/hostname r,
  /sys/fs/cgroup/** r,
  /etc/hosts r,
  /etc/resolv.conf r,
  /etc/nsswitch.conf r,
  /etc/localtime r,
  /usr/share/zoneinfo/** r,

  deny capability,
  deny mount,
  deny umount,
  deny pivot_root,
  deny ptrace,
  deny /proc/kcore r,
  deny /proc/sys/** w,
  deny /sys/** w,
  deny /dev/mem rw,
  deny /dev/kmem rw,
  deny /dev/port rw,
  deny /app/** w,
  deny /var/lib/tidepool/config/** w,

  signal (receive) set=(term, kill, int, quit, hup) peer=unconfined,
  signal (send, receive) peer=tidepool-scheduler,
}
