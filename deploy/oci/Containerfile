# deploy/oci/Containerfile
#
# One multi-stage, multi-target build producing the Tidepool image family:
#
#     build ──▶ tidepool-base ──▶ tidepool-collector   (adds gpgv)
#                            ├──▶ tidepool-api         (adds web/dist)
#                            ├──▶ tidepool-scheduler   (base as-is)
#                            └──▶ tidepool-utility     (dispatch + corpus CLIs)
#
# Principles:
#   * everything is built ONCE in the build stage; runtime images copy only
#     compiled output + production node_modules — no compilers, no npm cache
#   * every runtime image runs as the fixed unprivileged user 10001:10001
#     ("tidepool"), matching the ownership scheme install.sh sets up on the
#     host bind mounts (rootless user namespace maps it back to the operator)
#   * per-image dependency minimization:
#       - only the collector carries gpgv (signature verification)
#       - only the api carries the built frontend
#       - the scheduler and utility images carry neither
#     (all images share the node runtime + express; Tidepool's server has
#      exactly two npm dependencies, so there is no HTTP-client library to
#      strip from the dispatch image — collection uses node's built-in fetch,
#      and code that is never executed is denied execution by AppArmor and
#      egress by the network policy rather than by image surgery)
#   * images are immutable: all state lives on the /var/lib/tidepool mounts;
#     containers run with a read-only root filesystem (enforced in Quadlet)
#
# Build (from the repository root — deploy/scripts/install.sh does this):
#   BASE=$(deploy/scripts/pin-base.sh)                # digest-pinned base ref
#   TAG="0.3.0-g$(git rev-parse --short HEAD)"        # immutable local tag
#   podman build -f deploy/oci/Containerfile --target collector \
#     --build-arg BASE_IMAGE="$BASE" \
#     --build-arg TIDEPOOL_VERSION=0.3.0 --build-arg TIDEPOOL_GIT_COMMIT=$(git rev-parse HEAD) \
#     -t localhost/tidepool-collector:$TAG .
#   … and the same for api / scheduler / proxy / utility.
#
# Shared configurables (base image tag, internal port, container uid) come
# from deploy/deploy.yaml via install.sh's --build-arg lines; the ARG
# defaults below only serve bare `podman build` invocations.
#
# IMAGE DISCIPLINE (isolated-appliance evolution):
#   * BASE_IMAGE is an ARG so the base is pinned BY DIGEST at build time
#     (pin-base.sh resolves the current digest; CI fails builds that used
#     the floating tag). The default keeps ad-hoc developer builds working.
#   * install.sh tags images 0.3.0-g<commit> — rendered Quadlets reference
#     that immutable tag, never :latest.
#   * provenance ARGs are baked as ENV so every snapshot manifest and
#     replica publication records exactly which software produced it.

ARG BASE_IMAGE=docker.io/library/node:24-bookworm-slim

# --------------------------------------------------------------------- build
FROM ${BASE_IMAGE} AS build
WORKDIR /src

# dependency layers first for cache efficiency
# .npmrc carries engine-strict=true: the Node-version floor must hold INSIDE
# the image build too, failing at `npm ci` in seconds — not at the final
# image-node tripwire after a full compile on the wrong runtime.
COPY .npmrc package.json package-lock.json ./
COPY server/package.json server/package-lock.json ./server/
COPY web/package.json web/package-lock.json ./web/
# workspace root install: one lock, all components, hoisted — this is the
# BUILD toolchain (tsc, vite, types); the runtime images never see it
# --ignore-scripts: no dependency here needs lifecycle scripts, and this
# closes the npm install-time code-execution class entirely at build time.
RUN npm ci --ignore-scripts --no-audit --no-fund

COPY shared ./shared
COPY server ./server
COPY web ./web
# the build regenerates shared/deployConfig.generated.ts from deploy.yaml —
# the generator and its source must exist in the build context
COPY scripts ./scripts
COPY deploy/deploy.yaml ./deploy/deploy.yaml
RUN npm run build \
 # runtime node_modules: a STANDALONE production install against the
 # component's own lock (server/package-lock.json) — deterministic with no
 # monorepo knowledge; --workspaces=false keeps npm from resolving against
 # the workspace root. This is the per-component lock's entire job.
 && cd server && npm ci --ignore-scripts --omit=dev --workspaces=false --no-audit --no-fund

# ---------------------------------------------------------------------- base
# Shared runtime: node + compiled server + production deps + migrations.
# No shell tooling is added; the base image of node:24-bookworm-slim does
# contain /bin/sh (Debian), so interactive/shell execution is denied by the
# AppArmor profiles and the containers never require one.
FROM ${BASE_IMAGE} AS base
ARG TIDEPOOL_VERSION=""
ARG TIDEPOOL_GIT_COMMIT=""
ARG TIDEPOOL_IMAGE_DIGEST=""
ENV TIDEPOOL_VERSION=${TIDEPOOL_VERSION} \
    TIDEPOOL_GIT_COMMIT=${TIDEPOOL_GIT_COMMIT} \
    TIDEPOOL_IMAGE_DIGEST=${TIDEPOOL_IMAGE_DIGEST} \
    NODE_ENV=production \
    # canonical in-container layout, mirroring the host bind mounts 1:1 so
    # that AppArmor paths, documentation, and host paths all read the same
    TIDEPOOL_ROOT=/app \
    TIDEPOOL_CONFIG=/var/lib/tidepool/config/tidepool.config.json \
    TIDEPOOL_DATA_DIR=/var/lib/tidepool/corpus \
    TIDEPOOL_CACHE_DIR=/var/lib/tidepool/cache \
    TIDEPOOL_PUBLISHED_DIR=/var/lib/tidepool/published \
    TIDEPOOL_RUN_DIR=/var/lib/tidepool/run \
    NODE_OPTIONS=--disable-warning=ExperimentalWarning
WORKDIR /app
# fixed unprivileged identity; matches install.sh's chown of the bind mounts
RUN groupadd -g 10001 tidepool && useradd -r -u 10001 -g 10001 -d /app -s /usr/sbin/nologin tidepool \
 && mkdir -p /var/lib/tidepool
# the runtime base carries NO package manager and NO toolchain: node:slim
# ships npm/npx/corepack/yarn, and "the profiles deny executing them" is weaker
# than "they do not exist" — remove them so the image-contents CI gate
# (deploy/scripts/verify-image-contents.sh) can assert absence, not policy
RUN rm -rf /usr/local/lib/node_modules \
          /usr/local/bin/npm /usr/local/bin/npx /usr/local/bin/corepack \
          /usr/local/bin/yarn /usr/local/bin/yarnpkg /opt/yarn*

COPY --from=build /src/server/dist          ./server/dist
COPY --from=build /src/server/migrations    ./server/migrations
COPY --from=build /src/server/package.json  ./server/package.json
# Prove the Node baked into this image is major 24 — not a CI variable, the
# actual runtime binary every target inherits. Fails the build otherwise.
RUN node -e 'const m=+process.versions.node.split(".")[0];if(m!==24){console.error("FAIL: image Node major "+m+" != 24");process.exit(1)}console.log("image Node "+process.versions.node+" (major 24)")'
USER 10001:10001
# no ENTRYPOINT here: each target pins its exact process

# ----------------------------------------------------------------- collector
# The only image that verifies signatures, so the only one that carries gpgv.
# Keyrings are NOT baked in: they are host-owned trust anchors bind-mounted
# read-only at /var/lib/tidepool/keyrings (see quadlet + install.sh).
FROM base AS collector
USER 0
RUN apt-get update -qq \
 && apt-get install -y -qq --no-install-recommends gpgv \
 && rm -rf /var/lib/apt/lists/*
USER 10001:10001
CMD ["node", "server/dist/server/src/services/collector.js"]

# ----------------------------------------------------------------------- api
# Adds the built frontend; carries no gpgv and no keyrings.
FROM base AS api
ENV TIDEPOOL_WEB_DIST=/app/web/dist \
    TIDEPOOL_API_LISTEN=unix
COPY --from=build /src/web/dist ./web/dist
# no EXPOSE: the deployed API listens on a Unix socket only; the proxy
# image is the one with a TCP listener (dev TCP mode: unset TIDEPOOL_API_LISTEN)
CMD ["node", "server/dist/server/src/services/api.js"]

# -------------------------------------------------------------------- proxy
# The only network-facing image: a ~150-line node:http TCP→UDS forwarder
# with no corpus, snapshot, or config-content knowledge. This is what lets
# the API container run with --network=none.
FROM base AS proxy
ARG INTERNAL_PORT=8747
EXPOSE ${INTERNAL_PORT}
CMD ["node", "server/dist/server/src/services/proxy.js"]

# ------------------------------------------------------------------ scheduler
# Base as-is: it owns no data and fetches nothing — it only dials the
# collector's control socket (a Unix domain socket, not a network endpoint).
FROM base AS scheduler
CMD ["node", "server/dist/server/src/services/scheduler.js"]

# -------------------------------------------------------------------- utility
# Operator tooling: dispatch analysis and corpus export/import/status.
# Run ad hoc (never a long-lived service):
#   podman run --rm -v tidepool-corpus:/var/lib/tidepool/corpus \
#     localhost/tidepool-utility \
#     node server/dist/server/src/cli/dispatch.js --snapshot latest \
#       --store /var/lib/tidepool/corpus /project
FROM base AS utility
CMD ["node", "server/dist/server/src/cli/corpus.js", "status", "--data", "/var/lib/tidepool/corpus"]
